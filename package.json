{
  "name": "neurodesk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:gateway": "turbo run dev --filter=@neurodesk/gateway",
    "dev:desktop": "cd apps/desktop && pnpm tauri dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "setup": "pnpm install && docker compose -f infrastructure/docker/docker-compose.dev.yml up -d"
  },
  "devDependencies": {
    "turbo": "latest",
    "prettier": "^3.3.3",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@9.12.0"
}